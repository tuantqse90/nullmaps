{
  "version": 8,
  "name": "NullMaps VN Dark",
  "metadata": {
    "nullmaps:note": "Self-hosted Vietnam basemap. Glyphs + tiles served by Martin behind Caddy /tiles."
  },
  "glyphs": "/tiles/font/{fontstack}/{range}",
  "sources": {
    "vn": {
      "type": "vector",
      "url": "/tiles/vietnam"
    },
    "sovereignty": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": [
          {
            "type": "Feature",
            "properties": {
              "name": "Quần đảo Hoàng Sa (Việt Nam)"
            },
            "geometry": {
              "type": "Point",
              "coordinates": [
                112.0,
                16.5
              ]
            }
          },
          {
            "type": "Feature",
            "properties": {
              "name": "Quần đảo Trường Sa (Việt Nam)"
            },
            "geometry": {
              "type": "Point",
              "coordinates": [
                114.0,
                9.7
              ]
            }
          }
        ]
      }
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0d1117"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "vn",
      "source-layer": "water",
      "paint": {
        "fill-color": "#16323f"
      }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "vn",
      "source-layer": "landcover",
      "filter": [
        "==",
        [
          "get",
          "class"
        ],
        "wood"
      ],
      "paint": {
        "fill-color": "#16241a",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "vn",
      "source-layer": "landcover",
      "filter": [
        "in",
        [
          "get",
          "class"
        ],
        [
          "literal",
          [
            "grass",
            "park"
          ]
        ]
      ],
      "paint": {
        "fill-color": "#19271d",
        "fill-opacity": 0.55
      }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "vn",
      "source-layer": "landuse",
      "filter": [
        "==",
        [
          "get",
          "class"
        ],
        "residential"
      ],
      "minzoom": 9,
      "paint": {
        "fill-color": "#1a1f26",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "vn",
      "source-layer": "park",
      "paint": {
        "fill-color": "#15281b",
        "fill-opacity": 0.55
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "vn",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#1d3b49",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          0.5,
          16,
          3
        ]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "vn",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#1b212b",
        "fill-outline-color": "#232a35"
      }
    },
    {
      "id": "road-casing",
      "type": "line",
      "source": "vn",
      "source-layer": "transportation",
      "filter": [
        "in",
        [
          "get",
          "class"
        ],
        [
          "literal",
          [
            "motorway",
            "trunk",
            "primary",
            "secondary"
          ]
        ]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#3a3320",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          1.5,
          16,
          8
        ]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "vn",
      "source-layer": "transportation",
      "filter": [
        "in",
        [
          "get",
          "class"
        ],
        [
          "literal",
          [
            "tertiary",
            "minor",
            "service",
            "residential"
          ]
        ]
      ],
      "minzoom": 12,
      "paint": {
        "line-color": "#2b313b",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          12,
          0.6,
          18,
          4
        ]
      }
    },
    {
      "id": "road-major",
      "type": "line",
      "source": "vn",
      "source-layer": "transportation",
      "filter": [
        "in",
        [
          "get",
          "class"
        ],
        [
          "literal",
          [
            "motorway",
            "trunk",
            "primary",
            "secondary"
          ]
        ]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#4a5160",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          0.6,
          16,
          5
        ]
      }
    },
    {
      "id": "boundary-admin",
      "type": "line",
      "source": "vn",
      "source-layer": "boundary",
      "filter": [
        "<=",
        [
          "get",
          "admin_level"
        ],
        4
      ],
      "paint": {
        "line-color": "#5a4f70",
        "line-dasharray": [
          3,
          2
        ],
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          4,
          0.6,
          10,
          1.6
        ]
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "vn",
      "source-layer": "transportation_name",
      "minzoom": 13,
      "layout": {
        "symbol-placement": "line",
        "text-field": [
          "get",
          "name"
        ],
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 11
      },
      "paint": {
        "text-color": "#9aa4b2",
        "text-halo-color": "#0d1117",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "place-village",
      "type": "symbol",
      "source": "vn",
      "source-layer": "place",
      "filter": [
        "in",
        [
          "get",
          "class"
        ],
        [
          "literal",
          [
            "village",
            "suburb",
            "neighbourhood",
            "hamlet"
          ]
        ]
      ],
      "minzoom": 11,
      "layout": {
        "text-field": [
          "get",
          "name"
        ],
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 11
      },
      "paint": {
        "text-color": "#aab4c2",
        "text-halo-color": "#0d1117",
        "text-halo-width": 1.3
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "vn",
      "source-layer": "place",
      "filter": [
        "in",
        [
          "get",
          "class"
        ],
        [
          "literal",
          [
            "town",
            "city"
          ]
        ]
      ],
      "layout": {
        "text-field": [
          "get",
          "name"
        ],
        "text-font": [
          "Noto Sans Bold"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          6,
          12,
          12,
          18
        ]
      },
      "paint": {
        "text-color": "#e6edf3",
        "text-halo-color": "#0d1117",
        "text-halo-width": 1.6
      }
    },
    {
      "id": "sovereignty-label",
      "type": "symbol",
      "source": "sovereignty",
      "minzoom": 4,
      "layout": {
        "text-field": [
          "get",
          "name"
        ],
        "text-font": [
          "Noto Sans Bold"
        ],
        "text-size": 12,
        "text-max-width": 8,
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "#9fe870",
        "text-halo-color": "#0d1117",
        "text-halo-width": 1.8
      }
    }
  ]
}