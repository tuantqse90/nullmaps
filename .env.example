# NullMaps — copy to .env and adjust. .env is gitignored.

# --- Auth: one shared API key. My apps send this; services check it. ---
API_KEY=change-me-to-a-long-random-string

# --- Data ---
# Geofabrik Vietnam extract. Never switch to planet without explicit decision.
OSM_EXTRACT_URL=https://download.geofabrik.de/asia/vietnam-latest.osm.pbf
DATA_DIR=./data
RAW_DIR=./data/raw

# Rough mainland VN bbox: minLon,minLat,maxLon,maxLat (used for pmtiles extract)
VN_BBOX=102.1,8.2,109.5,23.4

# --- Tiles (Phase 1) ---
PMTILES_FILE=vietnam.pmtiles
MARTIN_PORT=3000
DEMO_PORT=8080

# --- Routing (Phase 2, reserved) ---
VALHALLA_PORT=8002

# --- Geocoder (Phase 3) ---
GEOCODER_PORT=2322

# --- Adapter (Phase 4) ---
# 8000 collides with many local apps; default to 8010.
ADAPTER_PORT=8010

# --- Postgres / PostGIS (reserved) ---
POSTGRES_USER=nullmaps
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nullmaps
POSTGRES_PORT=5432
