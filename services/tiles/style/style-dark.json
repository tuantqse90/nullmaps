      "source-layer": "contour",
      "minzoom": 11,
      "filter": [
        "!=",
        [
          "%",
          [
            "to-number",
            [
              "get",
              "elev"
            ]
          ],
          500
        ],
        0
      ],
      "paint": {
        "line-color": "#5a6b78",
        "line-opacity": 0.35,
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          11,
          0.3,
          15,
          0.8
