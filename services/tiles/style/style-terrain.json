      "source": "vn",
      "source-layer": "water",
      "paint": {
        "fill-color": "#a8d3e6"
      }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "vn",
      "source-layer": "landcover",
      "filter": [
        "==",
        [
          "get",
          "class"
        ],
        "wood"
      ],
      "paint": {
        "fill-color": "#c6e0bf",
        "fill-opacity": 0.55
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "vn",
      "source-layer": "landcover",
      "filter": [
        "in",
        [
          "get",
          "class"
        ],
