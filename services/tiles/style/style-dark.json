{
  "version": 8,
  "name": "NullMaps VN Dark",
  "metadata": {
    "nullmaps:note": "Self-hosted Vietnam basemap. Glyphs + tiles served by Martin behind Caddy /tiles."
  },
  "glyphs": "/tiles/font/{fontstack}/{range}",
  "sources": {
    "vn": {
      "type": "vector",
      "url": "/tiles/vietnam?v=z16"
    },
    "sovereignty": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": [
          {
            "type": "Feature",
            "properties": {
              "name": "Quần đảo Hoàng Sa (Việt Nam)"
            },
            "geometry": {
              "type": "Point",
              "coordinates": [
                112.0,
                16.5
              ]
            }
          },
          {
            "type": "Feature",
            "properties": {
              "name": "Quần đảo Trường Sa (Việt Nam)"
            },
            "geometry": {
              "type": "Point",
              "coordinates": [
                114.0,
                9.7
              ]
            }
          }
        ]
      }
    },
    "hillshade": {
      "type": "raster",
      "url": "/tiles/hillshade",
      "tileSize": 256
    },
    "contours": {
      "type": "vector",
      "url": "/tiles/contours"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0d1117"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "vn",
      "source-layer": "water",
      "paint": {
        "fill-color": "#16323f"
      }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "vn",
      "source-layer": "landcover",
      "filter": [
        "==",
        [
          "get",
          "class"
        ],
        "wood"
      ],
      "paint": {
        "fill-color": "#16241a",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "vn",
      "source-layer": "landcover",
      "filter": [
        "in",
        [
          "get",
          "class"
        ],
        [
          "literal",
          [
            "grass",
            "park"
          ]
        ]
      ],
      "paint": {
        "fill-color": "#19271d",
        "fill-opacity": 0.55
      }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "vn",
      "source-layer": "landuse",
      "filter": [
        "==",
        [
          "get",
          "class"
        ],
        "residential"
      ],
      "minzoom": 9,
      "paint": {
        "fill-color": "#1a1f26",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "vn",
      "source-layer": "park",
      "paint": {
        "fill-color": "#15281b",
        "fill-opacity": 0.55
      }
    },
    {
      "id": "hillshade",
      "type": "raster",
