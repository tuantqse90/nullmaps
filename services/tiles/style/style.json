{
  "version": 8,
  "name": "NullMaps VN Light",
  "metadata": {"nullmaps:note": "Self-hosted Vietnam basemap. Glyphs + tiles served by Martin behind Caddy /tiles."},
  "glyphs": "/tiles/font/{fontstack}/{range}",
  "sources": {
    "vn": {"type": "vector", "url": "/tiles/vietnam"},
    "sovereignty": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": [
          {"type": "Feature", "properties": {"name": "Quần đảo Hoàng Sa (Việt Nam)"},
           "geometry": {"type": "Point", "coordinates": [112.0, 16.5]}},
          {"type": "Feature", "properties": {"name": "Quần đảo Trường Sa (Việt Nam)"},
           "geometry": {"type": "Point", "coordinates": [114.0, 9.7]}}
        ]
      }
    }
  },
  "layers": [
    {"id": "background", "type": "background", "paint": {"background-color": "#eaeef0"}},
    {"id": "water", "type": "fill", "source": "vn", "source-layer": "water",
     "paint": {"fill-color": "#a8d3e6"}},
    {"id": "landcover-wood", "type": "fill", "source": "vn", "source-layer": "landcover",
     "filter": ["==", ["get", "class"], "wood"],
     "paint": {"fill-color": "#c6e0bf", "fill-opacity": 0.55}},
    {"id": "landcover-grass", "type": "fill", "source": "vn", "source-layer": "landcover",
     "filter": ["in", ["get", "class"], ["literal", ["grass", "park"]]],
     "paint": {"fill-color": "#d4eccc", "fill-opacity": 0.5}},
    {"id": "landuse-residential", "type": "fill", "source": "vn", "source-layer": "landuse",
     "filter": ["==", ["get", "class"], "residential"], "minzoom": 9,
     "paint": {"fill-color": "#e6e3dc", "fill-opacity": 0.5}},
    {"id": "park", "type": "fill", "source": "vn", "source-layer": "park",
     "paint": {"fill-color": "#cfe8c4", "fill-opacity": 0.5}},
    {"id": "waterway", "type": "line", "source": "vn", "source-layer": "waterway",
     "paint": {"line-color": "#a8d3e6",
       "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 16, 3]}},
    {"id": "building", "type": "fill", "source": "vn", "source-layer": "building", "minzoom": 13,
     "paint": {"fill-color": "#dcd6ca", "fill-outline-color": "#cdc7ba"}},
    {"id": "road-casing", "type": "line", "source": "vn", "source-layer": "transportation",
     "filter": ["in", ["get", "class"], ["literal", ["motorway", "trunk", "primary", "secondary"]]],
     "layout": {"line-cap": "round", "line-join": "round"},
     "paint": {"line-color": "#e3b04b",
       "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1.5, 16, 8]}},
    {"id": "road-minor", "type": "line", "source": "vn", "source-layer": "transportation",
     "filter": ["in", ["get", "class"], ["literal", ["tertiary", "minor", "service", "residential"]]],
     "minzoom": 12,
     "paint": {"line-color": "#ffffff",
       "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.6, 18, 4]}},
    {"id": "road-major", "type": "line", "source": "vn", "source-layer": "transportation",
     "filter": ["in", ["get", "class"], ["literal", ["motorway", "trunk", "primary", "secondary"]]],
     "layout": {"line-cap": "round", "line-join": "round"},
     "paint": {"line-color": "#ffffff",
       "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.6, 16, 5]}},
    {"id": "boundary-admin", "type": "line", "source": "vn", "source-layer": "boundary",
     "filter": ["<=", ["get", "admin_level"], 4],
     "paint": {"line-color": "#9a8fb0", "line-dasharray": [3, 2],
       "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.6, 10, 1.6]}},
    {"id": "road-label", "type": "symbol", "source": "vn", "source-layer": "transportation_name",
     "minzoom": 13,
     "layout": {"symbol-placement": "line", "text-field": ["get", "name"],
       "text-font": ["Noto Sans Regular"], "text-size": 11},
     "paint": {"text-color": "#555", "text-halo-color": "#fff", "text-halo-width": 1.2}},
    {"id": "place-village", "type": "symbol", "source": "vn", "source-layer": "place",
     "filter": ["in", ["get", "class"], ["literal", ["village", "suburb", "neighbourhood", "hamlet"]]],
     "minzoom": 11,
     "layout": {"text-field": ["get", "name"], "text-font": ["Noto Sans Regular"], "text-size": 11},
     "paint": {"text-color": "#5a5a5a", "text-halo-color": "#fff", "text-halo-width": 1.3}},
    {"id": "place-town", "type": "symbol", "source": "vn", "source-layer": "place",
     "filter": ["in", ["get", "class"], ["literal", ["town", "city"]]],
     "layout": {"text-field": ["get", "name"], "text-font": ["Noto Sans Bold"],
       "text-size": ["interpolate", ["linear"], ["zoom"], 6, 12, 12, 18]},
     "paint": {"text-color": "#1f3a2e", "text-halo-color": "#fff", "text-halo-width": 1.6}},
    {"id": "sovereignty-label", "type": "symbol", "source": "sovereignty", "minzoom": 4,
     "layout": {"text-field": ["get", "name"], "text-font": ["Noto Sans Bold"],
       "text-size": 12, "text-max-width": 8, "text-allow-overlap": false},
     "paint": {"text-color": "#163300", "text-halo-color": "#fff", "text-halo-width": 1.8}}
  ]
}
