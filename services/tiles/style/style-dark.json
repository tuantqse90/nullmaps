      "maxzoom": 14,
      "paint": {
        "raster-opacity": 0.3,
        "raster-resampling": "linear"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "vn",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#1d3b49",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          0.5,
          16,
          3
        ]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "vn",
      "source-layer": "building",
