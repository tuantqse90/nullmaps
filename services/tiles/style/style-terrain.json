{
  "version": 8,
  "name": "NullMaps VN Light",
  "metadata": {
    "nullmaps:note": "Self-hosted Vietnam basemap. Glyphs + tiles served by Martin behind Caddy /tiles."
  },
  "glyphs": "/tiles/font/{fontstack}/{range}",
  "sources": {
    "vn": {
      "type": "vector",
      "url": "/tiles/vietnam?v=z16"
    },
    "sovereignty": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": [
          {
            "type": "Feature",
            "properties": {
              "name": "Quần đảo Hoàng Sa (Việt Nam)"
            },
            "geometry": {
              "type": "Point",
              "coordinates": [
                112,
                16.5
              ]
            }
          },
          {
            "type": "Feature",
            "properties": {
              "name": "Quần đảo Trường Sa (Việt Nam)"
            },
            "geometry": {
              "type": "Point",
              "coordinates": [
                114,
                9.7
              ]
            }
          }
        ]
      }
    },
    "hillshade": {
      "type": "raster",
      "url": "/tiles/hillshade",
      "tileSize": 256
