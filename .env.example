# NullMaps — copy to .env and adjust. .env is gitignored.

# --- Auth: one shared API key. My apps send this; services check it. ---
API_KEY=change-me-to-a-long-random-string

# --- Gateway: the single PUBLIC entrypoint (prod publishes only this) ---
GATEWAY_PORT=8088
# The MARTIN/VALHALLA/GEOCODER/ADAPTER/NORMALIZER ports below are DEV-ONLY:
# docker-compose.override.yml publishes them for `make *-test`. In prod
# (docker-compose.yml alone) the engines are internal; reach them via the gateway.

# --- Data ---
# Geofabrik Vietnam extract. Never switch to planet without explicit decision.
OSM_EXTRACT_URL=https://download.geofabrik.de/asia/vietnam-latest.osm.pbf
DATA_DIR=./data
RAW_DIR=./data/raw

# Rough mainland VN bbox: minLon,minLat,maxLon,maxLat (used for pmtiles extract)
VN_BBOX=102.1,8.2,109.5,23.4

# --- Tiles (Phase 1) ---
PMTILES_FILE=vietnam.pmtiles
MARTIN_PORT=3000
DEMO_PORT=8080

# --- Routing (Phase 2, reserved) ---
VALHALLA_PORT=8002

# --- Geocoder (Phase 3) ---
GEOCODER_PORT=2322

# --- Adapter (Phase 4) ---
# 8000 collides with many local apps; default to 8010.
ADAPTER_PORT=8010

# --- Normalizer (Phase 5, optional AI address cleanup) ---
# Leave LLM_MODEL empty to keep the normalizer a no-op. To enable, set a model
# and a provider key (e.g. DashScope Qwen). Provider-agnostic via LiteLLM.
NORMALIZER_PORT=8100
LLM_MODEL=
# LLM_MODEL=dashscope/qwen-plus
# DASHSCOPE_API_KEY=sk-...
# or any OpenAI-compatible / self-hosted endpoint:
# LLM_MODEL=openai/qwen2.5-7b-instruct
# LLM_API_KEY=...
# LLM_API_BASE=http://host:port/v1

# --- Postgres / PostGIS (reserved) ---
POSTGRES_USER=nullmaps
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nullmaps
POSTGRES_PORT=5432
