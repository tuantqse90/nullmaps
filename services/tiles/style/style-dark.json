      "layout": {
        "icon-image": [
          "match",
          [
            "get",
            "class"
          ],
          "restaurant",
          "restaurant",
          "cafe",
          "cafe",
          "fast_food",
          "fast-food",
          "fuel",
          "fuel",
          "hospital",
          "hospital",
          "pharmacy",
          "pharmacy",
          "school",
          "school",
          "college",
          "college",
          "bank",
          "bank",
          "lodging",
